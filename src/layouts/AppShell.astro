---
import '../styles/global.css';

interface Props {
	lang: 'es' | 'en';
	title: string;
}

const { lang, title } = Astro.props;
const description =
	lang === 'es'
		? 'Clasificación del Mundial 2026 en vivo: resultados, tablas de los 12 grupos, mejores terceros y cruces actualizados con cada gol.'
		: 'Live World Cup 2026 standings: scores, all 12 group tables, best third-placed teams and knockout projections updated with every goal.';
const canonicalPath = lang === 'es' ? '/' : '/en/';
const canonicalUrl = new URL(canonicalPath, Astro.site);
const spanishUrl = new URL('/', Astro.site);
const englishUrl = new URL('/en/', Astro.site);
const socialImageUrl = new URL('/fwc2026live-share-wide-v2.jpg', Astro.site);
const structuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'WebSite',
			'@id': `${Astro.site}#website`,
			url: Astro.site,
			name: 'FWC2026 Live',
			inLanguage: ['es', 'en'],
		},
		{
			'@type': 'WebApplication',
			'@id': `${canonicalUrl}#app`,
			name: 'FWC2026 Live',
			url: canonicalUrl,
			description,
			applicationCategory: 'SportsApplication',
			operatingSystem: 'Any',
			browserRequirements: 'Requires a modern web browser with JavaScript',
			isAccessibleForFree: true,
			offers: {
				'@type': 'Offer',
				price: '0',
				priceCurrency: 'USD',
			},
			author: {
				'@type': 'Person',
				name: 'Luiti Escobar',
			},
			featureList: lang === 'es'
				? [
					'Clasificación del Mundial 2026 en vivo',
					'Resultados y eventos de partidos',
					'Tabla de mejores terceros',
					'Cruces proyectados de dieciseisavos',
					'Simulador de resultados',
					'Notificaciones de goles',
				]
				: [
					'Live World Cup 2026 standings',
					'Live match scores and events',
					'Best third-placed teams table',
					'Projected round-of-32 bracket',
					'Match result simulator',
					'Goal notifications',
				],
			inLanguage: lang,
		},
	],
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#080b10" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" href="/favicon.png" type="image/png" sizes="64x64" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.webmanifest" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang="es" href={spanishUrl} />
		<link rel="alternate" hreflang="en" href={englishUrl} />
		<link rel="alternate" hreflang="x-default" href={spanishUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:secure_url" content={socialImageUrl} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="FWC 2026 Live — Un gol mueve todo el Mundial" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta name="twitter:image:alt" content="FWC 2026 Live — Un gol mueve todo el Mundial" />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script is:inline>
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', async () => {
					const registration = await navigator.serviceWorker.register('/sw.js');
					await registration.update();
				});
			}
		</script>
	</body>
</html>
